{
  "name": "cv",
  "version": "0.0.1",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --prod",
    "build:ssr": "npm run build && ng build --prod --app ssr --output-hashing=false && npm run webpack:server",
    "build:firebase": "npm run build && ng build --prod --app firebase --output-hashing=false && mv ./dist/browser/index.html functions/dist-server",
    "webpack:server": "webpack --config webpack.server.config.js --progress --colors",
    "lint": "ng lint",
    "test": "ng test",
    "e2e": "ng e2e",
    "serve:ssr": "node dist/server",
    "serve:firebase": "firebase serve --only hosting,functions",
    "deploy:firebase": "firebase deploy --only hosting",
    "codecov": "codecov -f coverage/lcov.info"
  },
  "private": true,
  "dependencies": {
